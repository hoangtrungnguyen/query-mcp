# Query MCP Environment Variables
# Copy this file to .env and fill in your values

# ==========================================
# Required: LLM API Key
# ==========================================
# Z.ai API key
QUERY_MCP_API_KEY=d0662f7ffca1436ca9925c940fedd661.mJYqCfIg6KhS4OsG

# OR Anthropic API key (if using Claude)
# QUERY_MCP_API_KEY=sk-ant-your-anthropic-api-key

# ==========================================
# Optional: PostgreSQL Configuration
# ==========================================
# Database name (default: testdb)
POSTGRES_DB=testdb

# Database user (default: postgres)
POSTGRES_USER=postgres

# Database password (default: postgres)
POSTGRES_PASSWORD=postgres

# Database port (default: 5432)
POSTGRES_PORT=5432

# ==========================================
# Optional: LLM Provider Configuration
# ==========================================
# LLM provider: "zai" or "anthropic" (default: zai)
# LLM_PROVIDER=zai

# LLM model name
# For Z.ai: glm-5.1
# For Anthropic: claude-3-5-sonnet-20241022
# LLM_MODEL=glm-5.1

# ==========================================
# Usage: Copy to .env and set values
# ==========================================
# cp .env.example .env
# Edit .env with your values
# Load before running: set -a && source .env && set +a
