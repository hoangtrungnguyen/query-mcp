# Query MCP Environment Variables
# Copy this file to .env and fill in your values

# ==========================================
# Required: LLM API Key
# ==========================================
# Gemini API key (default provider, free tier available)
# Get yours at: https://aistudio.google.com/apikey
QUERY_MCP_API_KEY=your-gemini-api-key

# OR Z.ai API key
# QUERY_MCP_API_KEY=your-zai-api-key

# OR Anthropic API key (if using Claude)
# QUERY_MCP_API_KEY=sk-ant-your-anthropic-api-key

# ==========================================
# Optional: PostgreSQL Configuration
# ==========================================
# Database name (default: testdb)
POSTGRES_DB=testdb

# Database user (default: postgres)
POSTGRES_USER=postgres

# Database password (default: postgres)
POSTGRES_PASSWORD=postgres

# Database port (default: 5432)
POSTGRES_PORT=5432

# ==========================================
# Optional: LLM Provider Configuration
# ==========================================
# LLM provider: "gemini", "zai", or "anthropic" (default: gemini)
# LLM_PROVIDER=gemini

# LLM model name
# For Gemini: gemini-2.5-flash, gemini-2.0-flash
# For Z.ai: glm-5.1
# For Anthropic: claude-3-5-sonnet-20241022
# LLM_MODEL=gemini-2.5-flash

# ==========================================
# Usage: Copy to .env and set values
# ==========================================
# cp .env.example .env
# Edit .env with your values
# Load before running: set -a && source .env && set +a
